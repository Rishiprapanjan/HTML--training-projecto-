<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Employee Management Automation Suite" verbose="1">
    
    <!-- Register our custom test listener for reports and screenshot capture -->
    <listeners>
        <listener class-name="com.employee.automation.listeners.TestListener" />
    </listeners>

    <!-- Define a group of tests to execute -->
    <test name="HR Portal Core Workflows">
        <classes>
            <!-- Login, Invalid Login and Logout Tests -->
            <class name="com.employee.automation.tests.LoginTests" />
            
            <!-- Employee CRUD (Add, Search, Edit, Delete) Tests -->
            <class name="com.employee.automation.tests.EmployeeTests" />
        </classes>
    </test>
</suite>
